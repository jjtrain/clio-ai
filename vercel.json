{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx pnpm@8.14.0 build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "HUSKY=0 npx pnpm@8.14.0 install",
  "crons": [
    {
      "path": "/api/cron/followups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reports",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/risk-scan",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/financial-insights",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/zoom-sync",
      "schedule": "0 */2 * * *"
    }
  ]
}
