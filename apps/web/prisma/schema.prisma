enum ReportType {
  FINANCIAL
  MATTERS
  CLIENTS
  TIME
  LEADS
  APPOINTMENTS
  CUSTOM
}

model ReportDefinition {
  id                 String             @id @default(cuid())
  name               String
  description        String?            @db.Text
  reportType         ReportType
  dataSource         String
  columns            String             @db.Text
  filters            String             @db.Text
  groupBy            String?
  sortBy             String?
  sortDirection      String             @default("desc")
  aggregations       String?            @db.Text
  chartType          String?
  chartConfig        String?            @db.Text
  dateRange          String?            @db.Text
  isScheduled        Boolean            @default(false)
  scheduleFrequency  String?
  scheduleRecipients String?            @db.Text
