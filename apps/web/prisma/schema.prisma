  updatedAt              DateTime        @updatedAt

  @@index([matterId])
}

model BillingForecast {
  id                 String       @id @default(cuid())
  matterId           String?
  matter             Matter?      @relation(fields: [matterId], references: [id], onDelete: Cascade)
  forecastType       ForecastType @default(MONTHLY)
  period             String
  projectedRevenue   Decimal      @db.Decimal(12, 2)
  projectedHours     Decimal?     @db.Decimal(10, 2)
  projectedExpenses  Decimal?     @db.Decimal(10, 2)
  actualRevenue      Decimal?     @db.Decimal(12, 2)
  actualHours        Decimal?     @db.Decimal(10, 2)
  variance           Decimal?     @db.Decimal(12, 2)
  variancePercentage Decimal?     @db.Decimal(5, 2)
  methodology        String?
  aiGenerated        Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([matterId])
  @@index([forecastType])
  @@index([period])
}

enum RiskCategory {
  BILLING
  COMPLIANCE
  DEADLINE
  CLIENT
  TRUST
  PRODUCTIVITY
  CONFLICT
  FINANCIAL
}

enum RiskSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum RiskAlertStatus {
  NEW
  ACKNOWLEDGED
  INVESTIGATING
  RESOLVED
  DISMISSED
}

model RiskAlert {
  id               String          @id @default(cuid())
  category         RiskCategory
  severity         RiskSeverity
  title            String
  description      String          @db.Text
  source           String
  entityType       String?
  entityId         String?
  matterId         String?
  matter           Matter?         @relation(fields: [matterId], references: [id], onDelete: SetNull)
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status           RiskAlertStatus @default(NEW)
  resolvedAt       DateTime?
  resolvedBy       String?
  resolution       String?         @db.Text
  aiAnalysis       String?         @db.Text
  aiRecommendation String?         @db.Text
  data             String?         @db.Text
  isAutoGenerated  Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([matterId])
  @@index([clientId])
  @@index([createdAt])
}

model RiskScanLog {
  id              String   @id @default(cuid())
  scanType        String
  alertsGenerated Int      @default(0)
  duration        Int?
  summary         String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model RiskSettings {
  id                       String   @id @default("default")
  isEnabled                Boolean  @default(true)
  autoScanEnabled          Boolean  @default(true)
  scanFrequency            String   @default("daily")
  billingAnomalyThreshold  Decimal  @default(2.0) @db.Decimal(5, 2)
  trustOverdraftAlert      Boolean  @default(true)
  deadlineAlertDays        Int      @default(7)
  inactivityAlertDays      Int      @default(30)
  unusualTimeEntryHours    Decimal  @default(10.0) @db.Decimal(5, 2)
  duplicateEntryDetection  Boolean  @default(true)
  conflictAutoCheck        Boolean  @default(true)
  notifyOnCritical         Boolean  @default(true)
  notifyEmail              String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ============================================
// MEDICAL RECORDS & LIENS (PERSONAL INJURY)
// ============================================

model MedicalProvider {
  id            String       @id @default(cuid())
  name          String
  type          ProviderType
  phone         String?
  fax           String?
  email         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  contactPerson String?
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  records       MedicalRecord[]
  liens         MedicalLien[]

  @@index([name])
  @@index([type])
}

model MedicalRecord {
  id                 String              @id @default(cuid())
  matterId           String
  matter             Matter              @relation(fields: [matterId], references: [id], onDelete: Cascade)
  providerId         String?
  provider           MedicalProvider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerName       String
  recordType         MedicalRecordType
  dateOfService      DateTime
  endDate            DateTime?
  description        String?             @db.Text
  diagnosis          String?             @db.Text
  treatingPhysician  String?
  totalCharges       Decimal?            @db.Decimal(12, 2)
  amountPaid         Decimal?            @db.Decimal(12, 2)
  adjustments        Decimal?            @db.Decimal(12, 2)
  outstandingBalance Decimal?            @db.Decimal(12, 2)
  requestStatus      RecordRequestStatus @default(NOT_REQUESTED)
  requestedAt        DateTime?
  receivedAt         DateTime?
  documentId         String?
  notes              String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([matterId])
  @@index([providerId])
  @@index([dateOfService])
  @@index([requestStatus])
}

model MedicalLien {
  id                  String           @id @default(cuid())
  matterId            String
  matter              Matter           @relation(fields: [matterId], references: [id], onDelete: Cascade)
  providerId          String?
  provider            MedicalProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerName        String
  lienType            LienType
  originalAmount      Decimal          @db.Decimal(12, 2)
  negotiatedAmount    Decimal?         @db.Decimal(12, 2)
  paidAmount          Decimal?         @db.Decimal(12, 2)
  status              LienStatus       @default(PENDING)
  priority            Int              @default(0)
  lienHolderName      String
  lienHolderContact   String?          @db.Text
  assertedDate        DateTime?
  dueDate             DateTime?
  lienLetterReceivedAt DateTime?
  reductionPercentage Decimal?         @db.Decimal(5, 2)
  reductionNotes      String?          @db.Text
  documentId          String?
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([matterId])
  @@index([lienType])
  @@index([status])
}

model InjuryCaseDetails {
  id                    String            @id @default(cuid())
  matterId              String            @unique
  matter                Matter            @relation(fields: [matterId], references: [id], onDelete: Cascade)
  dateOfIncident        DateTime
  incidentType          IncidentType
  incidentDescription   String?           @db.Text
  injuryDescription     String?           @db.Text
  liabilityAssessment   String?           @db.Text
  insuranceCompany      String?
  claimNumber           String?
  adjusterName          String?
  adjusterPhone         String?
  adjusterEmail         String?
  policyLimits          Decimal?          @db.Decimal(12, 2)
  umUimLimits           Decimal?          @db.Decimal(12, 2)
  totalMedicalSpecials  Decimal?          @db.Decimal(12, 2)
  totalLienAmount       Decimal?          @db.Decimal(12, 2)
  demandAmount          Decimal?          @db.Decimal(12, 2)
  settlementAmount      Decimal?          @db.Decimal(12, 2)
  attorneyFeePercentage Decimal?          @db.Decimal(5, 2)
  attorneyFeeAmount     Decimal?          @db.Decimal(12, 2)
  netToClient           Decimal?          @db.Decimal(12, 2)
  caseStatus            InjuryCaseStatus  @default(PRE_SUIT)
  aiSummary             String?           @db.Text
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([matterId])
  @@index([caseStatus])
}

model SettlementDistribution {
  id               String             @id @default(cuid())
  matterId         String
  matter           Matter             @relation(fields: [matterId], references: [id], onDelete: Cascade)
  settlementAmount Decimal            @db.Decimal(12, 2)
