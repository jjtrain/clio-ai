  clientId    String?
  client      Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())

  @@index([entryId])
  @@index([accountId])
  @@index([matterId])
}

model Expense {
  id                String          @id @default(cuid())
