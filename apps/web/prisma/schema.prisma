  apiKey           String?  @db.Text
  clientId         String?
  testMode         Boolean  @default(true)
  callbackUrl      String?
  brandId          String?
  webhookSecret    String?
  defaultFromName  String?
  defaultFromEmail String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum SignatureStatus {
  DRAFT
  PENDING_CLIENT
  CLIENT_SIGNED
  PENDING_ATTORNEY
  COMPLETED
  CANCELLED
  EXPIRED
}

