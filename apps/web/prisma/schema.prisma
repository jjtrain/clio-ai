  timesMatched    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([matchType])
  @@index([isActive])
}

model BankFeed {
  id               String     @id @default(cuid())
  bankAccountId    String     @unique
  bankAccount      BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  provider         String     @default("manual")
  lastSyncAt       DateTime?
  syncStatus       SyncStatus @default(IDLE)
  errorMessage     String?
  plaidAccessToken String?
  plaidItemId      String?
  csvFormat        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([bankAccountId])
}

model ReconciliationMatch {
  id                  String               @id @default(cuid())
  sessionId           String
  session             ReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  bankTransactionId   String
  bankTransaction     BankTransaction      @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  matchedEntityType   String?
  matchedEntityId     String?
  matchType           AutoMatchType
  confidence          Decimal?             @db.Decimal(5, 2)
  isConfirmed         Boolean              @default(false)
  createdAt           DateTime             @default(now())

  @@index([sessionId])
  @@index([bankTransactionId])
  @@index([matchType])
}

enum MatchType {
