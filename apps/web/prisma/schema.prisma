// ── Statute of Limitations Tracker ────────────────────────────────────

enum AccrualBasis {
  AB_DATE_OF_INCIDENT
  AB_DATE_OF_DISCOVERY
  AB_DATE_OF_LAST_TREATMENT
  AB_DATE_OF_TERMINATION
  AB_DATE_OF_BREACH
  AB_DATE_OF_PUBLICATION
  AB_CUSTOM
}

enum SOLStatus {
  SOL_ACTIVE
  SOL_TOLLED
  SOL_EXPIRED
  SOL_FILED
  SOL_EXTENDED
  SOL_WAIVED
  SOL_DISMISSED
}

enum SOLUrgency {
  SOL_SAFE
  SOL_MONITOR
  SOL_WARNING
  SOL_CRITICAL
  SOL_URG_EXPIRED
}

enum SOLRiskLevel {
  SRL_LOW
  SRL_MEDIUM
  SRL_HIGH
  SRL_EXTREME
}

enum SOLAlertType {
  SAT_DAY_365
  SAT_DAY_180
  SAT_DAY_90
  SAT_DAY_60
  SAT_DAY_30
  SAT_DAY_14
  SAT_DAY_7
  SAT_DAY_3
  SAT_DAY_1
  SAT_EXPIRED
  SAT_TOLLING_ENDED
  SAT_NOTICE_DUE
  SAT_CUSTOM
}

