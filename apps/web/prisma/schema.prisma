  smsAlerts               Boolean           @default(true)
  inAppAlerts             Boolean           @default(true)
  dailyDigestEnabled      Boolean           @default(true)
  dailyDigestTime         String            @default("08:00")
  dailyDigestRecipients   String?           @db.Text
  weeklyReportEnabled     Boolean           @default(true)
  weeklyReportDay         String            @default("Monday")
  criticalThresholdDays   Int               @default(90)
  warningThresholdDays    Int               @default(180)
  monitorThresholdDays    Int               @default(365)
  autoCreateDocketEntry   Boolean           @default(true)
  autoCreateFromMatter    Boolean           @default(false)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
}

