model SignatureRequest {
  id                String          @id @default(cuid())
  documentId        String?
  document          Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  matterId          String
  matter            Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)

  title             String
  description       String?         @db.Text
  status            SignatureStatus @default(DRAFT)
  documentContent   String?         @db.Text

  // Client signer
  clientName        String
  clientEmail       String
  clientSignature   String?         @db.Text
  clientSignedAt    DateTime?
  clientIpAddress   String?

  // Attorney signer
  attorneyName      String?
  attorneySignature String?         @db.Text
  attorneySignedAt  DateTime?
  attorneyIpAddress String?

  // Signing link
  signingToken      String          @unique

  // HelloSign integration
  helloSignRequestId     String?       @unique
  helloSignSignatureId   String?
  signingProvider        String        @default("builtin") // "builtin" or "hellosign"
  helloSignFileUrl       String?       @db.Text
  helloSignStatusData    String?       @db.Text // JSON
  hellosignStatus        String?       // awaiting_signature, signed, declined, etc.
  hellosignSignUrl       String?       @db.Text
  hellosignAttorneySignUrl String?     @db.Text
  hellosignDocumentUrl   String?       @db.Text
  attorneyEmail          String?

  // Lifecycle
  expiresAt         DateTime?
  sentAt            DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  setItems          DocumentSetItem[]

  @@index([matterId])
  @@index([documentId])
  @@index([signingToken])
  @@index([status])
  @@index([helloSignRequestId])
}

model HelloSignSettings {
  id               String   @id @default("default")
