model ChartOfAccounts {
  id             String           @id @default(cuid())
  accountNumber  String           @unique
  name           String
  type           AccountType
  subType        String?
  description    String?
  parentId       String?
  parent         ChartOfAccounts? @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       ChartOfAccounts[] @relation("AccountHierarchy")
  isActive       Boolean          @default(true)
  isSystem       Boolean          @default(false)
  normalBalance  BalanceDirection
  currentBalance Decimal          @default(0) @db.Decimal(14, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  journalLines   JournalLine[]
  expenses       Expense[]
  budgets        BudgetItem[]
  bankAccount    BankAccount?

  @@index([accountNumber])
  @@index([type])
  @@index([parentId])
  @@index([isActive])
}

model JournalEntry {
  id          String        @id @default(cuid())
