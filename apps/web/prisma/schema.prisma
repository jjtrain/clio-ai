  sentAt            DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  setItems          DocumentSetItem[]

  @@index([matterId])
  @@index([documentId])
  @@index([signingToken])
  @@index([status])
  @@index([helloSignRequestId])
}

