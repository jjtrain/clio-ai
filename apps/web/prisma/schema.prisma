enum WebsitePageType {
  HOME
  ABOUT
  PRACTICE_AREAS
  CONTACT
  TESTIMONIALS
  BLOG
  CUSTOM
}

// ============================================
// AI PRACTICE MANAGEMENT ASSISTANT
// ============================================

model AiAction {
  id            String         @id @default(cuid())
  type          AiActionType
  status        AiActionStatus @default(PENDING)
  title         String
  description   String?        @db.Text

  sourceType    String?
  sourceId      String?

  matterId      String?
  matter        Matter?        @relation(fields: [matterId], references: [id], onDelete: SetNull)

  generatedData String?        @db.Text
  reviewedAt    DateTime?
  appliedAt     DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([matterId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

enum AiActionType {
  DEADLINE_EXTRACTION
  CLIENT_UPDATE_DRAFT
  TIME_TO_INVOICE
  MATTER_SUMMARY
  TASK_SUGGESTION
}

enum AiActionStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

model AiAssistantSettings {
  id                    String   @id @default("default")
  isEnabled             Boolean  @default(true)
  autoExtractDeadlines  Boolean  @default(false)
  autoSuggestTasks      Boolean  @default(false)
  aiModel               String   @default("claude-sonnet-4-20250514")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// AI LEGAL RESEARCH WORKSPACE
// ============================================

model ResearchSession {
  id          String          @id @default(cuid())
  matterId    String?
  matter      Matter?         @relation(fields: [matterId], references: [id], onDelete: SetNull)
  title       String
  description String?         @db.Text
  status      ResearchStatus  @default(ACTIVE)

  messages    ResearchMessage[]
  notes       ResearchNote[]
  sources     ResearchSource[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([matterId])
  @@index([status])
  @@index([createdAt])
}

model ResearchMessage {
  id        String       @id @default(cuid())
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ResearchRole
  content   String       @db.Text
  metadata  String?      @db.Text

  createdAt DateTime     @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model ResearchNote {
  id        String          @id @default(cuid())
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String
  content   String          @db.Text
  tags      String?         @db.Text
  isPinned  Boolean         @default(false)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([sessionId])
}

model ResearchSource {
  id             String             @id @default(cuid())
  sessionId      String
  session        ResearchSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title          String
  citation       String?
  url            String?
  sourceType     ResearchSourceType
  summary        String?            @db.Text
  relevanceScore Int?
  content        String?            @db.Text

  createdAt      DateTime           @default(now())

  @@index([sessionId])
}

enum ResearchStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ResearchRole {
  USER
  AI
  SYSTEM
}

enum ResearchSourceType {
  CASE_LAW
  STATUTE
  REGULATION
  SECONDARY
  WEB
  MANUAL
}

model ResearchSettings {
  id                    String   @id @default("default")
  vlexApiKey            String?
  vlexEnabled           Boolean  @default(false)
  defaultJurisdiction   String   @default("Federal")
  defaultModel          String   @default("claude-sonnet-4-20250514")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// AI DOCUMENT DRAFTING & TEMPLATES
// ============================================

model DocumentTemplate {
  id           String           @id @default(cuid())
  name         String
  description  String?          @db.Text
  category     DocumentCategory
  practiceArea String?
  content      String           @db.Text
  variables    String           @db.Text
  isActive     Boolean          @default(true)
  usageCount   Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  drafts       DraftDocument[]

  @@index([category])
  @@index([practiceArea])
  @@index([isActive])
}

model DraftDocument {
  id             String            @id @default(cuid())
  matterId       String?
  matter         Matter?           @relation(fields: [matterId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  templateId     String?
  template       DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title          String
  content        String            @db.Text
  status         DraftStatus       @default(DRAFT)
  variableValues String?           @db.Text
  aiGenerated    Boolean           @default(false)
  aiPrompt       String?           @db.Text
  version        Int               @default(1)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  setItems       DocumentSetItem[]

  @@index([matterId])
  @@index([clientId])
  @@index([status])
  @@index([templateId])
}

model DocumentSet {
  id          String            @id @default(cuid())
  name        String
  description String?           @db.Text
  matterId    String?
  matter      Matter?           @relation(fields: [matterId], references: [id], onDelete: SetNull)
  clientId    String?
  status      DocumentSetStatus @default(ASSEMBLING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       DocumentSetItem[]

  @@index([matterId])
}

model DocumentSetItem {
  id                 String            @id @default(cuid())
  documentSetId      String
  documentSet        DocumentSet       @relation(fields: [documentSetId], references: [id], onDelete: Cascade)
  draftDocumentId    String?
  draftDocument      DraftDocument?    @relation(fields: [draftDocumentId], references: [id], onDelete: SetNull)
  signatureRequestId String?
  signatureRequest   SignatureRequest? @relation(fields: [signatureRequestId], references: [id], onDelete: SetNull)
  title              String
  sortOrder          Int               @default(0)
  isComplete         Boolean           @default(false)
  createdAt          DateTime          @default(now())

  @@index([documentSetId])
}

enum DocumentCategory {
  ENGAGEMENT
  PLEADING
  MOTION
  LETTER
  AGREEMENT
  DISCOVERY
  COURT_FORM
  OTHER
}

enum DraftStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
  SIGNED
}

enum DocumentSetStatus {
  ASSEMBLING
  READY
  SENT
  COMPLETED
}
