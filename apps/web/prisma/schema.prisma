  SDM_IN_APP
  SDM_EMAIL
  SDM_SMS
  SDM_ALL
}

enum SOLDeliveryStatus {
  SDS_PENDING
  SDS_SENT
  SDS_DELIVERED
  SDS_FAILED
  SDS_ACKNOWLEDGED
}

model StatuteOfLimitations {
  id                      String        @id @default(cuid())
  matterId                String
  matter                  Matter        @relation("MatterSOL", fields: [matterId], references: [id], onDelete: Cascade)
  clientId                String?
  departmentId            String?
  practiceArea            String
  jurisdiction            String
  jurisdictionProfileId   String?
  causeOfAction           String
  causeOfActionDetail     String?       @db.Text
  accrualDate             DateTime
  accrualBasis            AccrualBasis
  accrualNotes            String?       @db.Text
  limitationPeriod        String
  limitationDays          Int
  expirationDate          DateTime
  statute                 String?
  statuteDescription      String?       @db.Text
  statuteUrl              String?
  status                  SOLStatus     @default(SOL_ACTIVE)
  daysRemaining           Int?
  urgency                 SOLUrgency    @default(SOL_SAFE)
  tollingApplied          Boolean       @default(false)
  tollingReason           String?       @db.Text
  tollingStartDate        DateTime?
  tollingEndDate          DateTime?
  tollingDays             Int           @default(0)
  originalExpirationDate  DateTime?
  filedDate               DateTime?
  filedDocumentId         String?
  filedDocketEntryId      String?
  noticeOfClaimRequired   Boolean       @default(false)
  noticeOfClaimDeadline   DateTime?
  noticeOfClaimFiled      Boolean       @default(false)
  noticeOfClaimDate       DateTime?
  noticeOfClaimDocId      String?
  relatedSOLIds           String?       @db.Text
  alertSchedule           String?       @db.Text
  lastAlertSent           DateTime?
  lastAlertType           String?
  assignedTo              String?
  assignedToEmail         String?
  notes                   String?       @db.Text
  riskLevel               SOLRiskLevel  @default(SRL_LOW)
  riskNotes               String?       @db.Text
  alerts                  SOLAlert[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([matterId])
  @@index([practiceArea])
  @@index([jurisdiction])
  @@index([expirationDate])
  @@index([status])
  @@index([urgency])
  @@index([daysRemaining])
  @@index([riskLevel])
}

model SOLAlert {
  id              String            @id @default(cuid())
  solId           String
  sol             StatuteOfLimitations @relation(fields: [solId], references: [id], onDelete: Cascade)
  matterId        String
  alertType       SOLAlertType
  severity        SOLAlertSeverity
  title           String
  message         String            @db.Text
  recipientEmail  String?
  recipientName   String?
  deliveryMethod  SOLDeliveryMethod @default(SDM_ALL)
  deliveredAt     DateTime?
  deliveryStatus  SOLDeliveryStatus @default(SDS_PENDING)
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  escalatedTo     String?
  escalatedAt     DateTime?
  createdAt       DateTime          @default(now())

  @@index([solId])
  @@index([alertType])
  @@index([severity])
  @@index([deliveryStatus])
  @@index([createdAt])
}

model SOLTemplate {
  id                      String        @id @default(cuid())
  practiceArea            String
  jurisdiction            String
  causeOfAction           String
  limitationPeriod        String
  limitationDays          Int
  statute                 String
  statuteDescription      String?       @db.Text
  accrualBasis            AccrualBasis
  accrualDescription      String?
