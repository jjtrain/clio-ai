  @@index([reportId])
  @@index([createdAt])
}

model MarketingSpend {
  id        String   @id @default(cuid())
  source    String
  amount    Decimal  @db.Decimal(10, 2)
  period    String   // YYYY-MM format
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, period])
  @@index([source])
  @@index([period])
}

enum FeeType {
  HOURLY
  FLAT_FEE
  CONTINGENCY
  HYBRID
  RETAINER
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum ForecastType {
  MONTHLY
  QUARTERLY
  ANNUAL
  MATTER_COMPLETION
}

model MatterValuation {
  id                     String          @id @default(cuid())
  matterId               String          @unique
  matter                 Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  estimatedValue         Decimal         @db.Decimal(12, 2)
  estimatedHours         Decimal?        @db.Decimal(10, 2)
  estimatedFees          Decimal?        @db.Decimal(12, 2)
  estimatedCosts         Decimal?        @db.Decimal(10, 2)
  feeType                FeeType         @default(HOURLY)
  contingencyPercentage  Decimal?        @db.Decimal(5, 2)
  retainerAmount         Decimal?        @db.Decimal(10, 2)
  hourlyRate             Decimal?        @db.Decimal(10, 2)
