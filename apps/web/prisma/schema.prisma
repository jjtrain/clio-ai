  displayOrder            Int           @default(0)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([practiceArea, jurisdiction, causeOfAction])
  @@index([practiceArea])
  @@index([jurisdiction])
  @@index([causeOfAction])
}

model SOLSettings {
  id                      String            @id @default("default")
  alertScheduleDays       String            @default("365,180,90,60,30,14,7,3,1")
  escalationEnabled       Boolean           @default(true)
  escalationAfterHours    Int               @default(24)
  escalationRecipient     String?
